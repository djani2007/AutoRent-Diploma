@model LoginViewModel
@{
    ViewData["Title"] = "Влизане в профил";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5 col-lg-4">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-4 rounded-top-4">
                    <h3 class="mb-1">
                        <i class="bi bi-person-circle me-2"></i>Влизане в профил
                    </h3>
                    <p class="mb-0 small">Въведете данните си за достъп</p>
                </div>

                <div class="card-body p-4">
                    <form asp-action="Login" method="post">
                        <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Имейл адрес</label>
                            <input asp-for="Email" class="form-control form-control-lg" placeholder="example@email.com" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Парола</label>
                            <input asp-for="Password" class="form-control form-control-lg" placeholder="Въведете парола" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>

                        <div class="mb-4 form-check">
                            <input asp-for="RememberMe" class="form-check-input" />
                            <label asp-for="RememberMe" class="form-check-label">Запомни ме</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-box-arrow-in-right me-1"></i> Влизане
                            </button>
                        </div>
                    </form>

                    <hr class="my-4" />

                    <p class="text-center mb-0">
                        Нямате профил?
                        <a asp-action="Register" class="fw-semibold">Регистрирайте се</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>