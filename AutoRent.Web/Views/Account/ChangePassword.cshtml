@model AutoRent.Web.ViewModels.ChangePasswordViewModel

@{
    ViewData["Title"] = "Смяна на парола";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-primary text-white py-4">
                    <h3 class="mb-0">
                        <i class="bi bi-key me-2"></i> Смяна на парола
                    </h3>
                </div>

                <div class="card-body p-4">
                    <form asp-action="ChangePassword" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="CurrentPassword" class="form-label">Текуща парола</label>
                            <input asp-for="CurrentPassword" class="form-control form-control-lg" placeholder="Въведете текущата парола" />
                            <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">Нова парола</label>
                            <input asp-for="NewPassword" class="form-control form-control-lg" placeholder="Въведете нова парола" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Потвърди нова парола</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" placeholder="Повторете новата парола" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">
                                <i class="bi bi-check-circle me-1"></i> Запази новата парола
                            </button>

                            <a asp-action="Profile" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Назад към профила
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}