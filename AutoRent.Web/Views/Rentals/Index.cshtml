@model IEnumerable<Rental>
@{
    ViewData["Title"] = "Моите наеми";
}

<div class="container py-5">
    <h1 class="mb-4"><i class="bi bi-calendar-check"></i> Моите наеми</h1>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <h4 class="mt-3">Нямате резервации</h4>
            <p class="text-muted">Разгледайте нашите автомобили и направете първата си резервация.</p>
            <a asp-controller="Cars" asp-action="Index" class="btn btn-primary">
                <i class="bi bi-car-front"></i> Разгледай автомобилите
            </a>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Автомобил</th>
                        <th>Начало</th>
                        <th>Край</th>
                        <th>Дни</th>
                        <th>Сума</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var rental in Model)
                    {
                        <tr>
                            <td>@rental.Id</td>
                            <td>@rental.Car.FullName</td>
                            <td>@rental.StartDate.ToString("dd.MM.yyyy")</td>
                            <td>@rental.EndDate.ToString("dd.MM.yyyy")</td>
                            <td>@rental.TotalDays</td>
                            <td>@rental.TotalPrice.ToString("N2") €</td>
                            <td>
                                @switch (rental.Status)
                                {
                                    case "Pending":
                                        <span class="badge bg-warning">В изчакване</span>
                                        break;
                                    case "Active":

                                        if (rental.EndDate.Date < DateTime.Today)

                                        {
                                            <span class="badge bg-secondary">Изтекъл</span>
                                        }

                                        else

                                        {
                                            <span class="badge bg-success">Активен</span>
                                        }

                                        break;
                                    case "Completed":
                                        <span class="badge bg-secondary">Завършен</span>
                                        break;
                                    case "Cancelled":
                                        <span class="badge bg-danger">Отказан</span>
                                        break;
                                    default:
                                        <span class="badge bg-info">@rental.Status</span>
                                        break;
                                }
                            </td>
                            <td>
                                <a asp-action="Details" asp-route-id="@rental.Id" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i>
                                </a>
                                @if (rental.Status == "Pending")
                                {
                                    <form asp-action="Cancel" asp-route-id="@rental.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Сигурни ли сте, че искате да откажете резервацията?');">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
