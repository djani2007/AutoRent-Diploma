@model AutoRent.Web.ViewModels.ContactViewModel

@{
    ViewData["Title"] = "Контакти";
}

<div class="container py-5">
    <h1 class="text-center mb-5">Свържете се с нас</h1>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="card h-100">
                <div class="card-body">
                    <h4><i class="bi bi-geo-alt text-primary"></i> Адрес</h4>
                    <p>бул. "Априлско възтание" 70<br>7200 Разград, България</p>

                    <h4 class="mt-4"><i class="bi bi-telephone text-primary"></i> Телефон</h4>
                    <p>+359 897 411 494</p>

                    <h4 class="mt-4"><i class="bi bi-envelope text-primary"></i> Email</h4>
                    <p>
                        info@autorent.bg<br>
                        support@autorent.bg<br>
                        admin@autorent.com
                    </p>

                    <h4 class="mt-4"><i class="bi bi-clock text-primary"></i> Работно време</h4>
                    <p>Понеделник - Петък: 08:00 - 18:00<br>Събота: 09:00 - 14:00<br>Неделя: Почивен ден</p>
                </div>
            </div>
        </div>

        <div class="col-lg-6">
            <div class="card">
                <div class="card-body">
                    <h4>Изпратете ни съобщение</h4>

                    <form asp-action="Contact" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">Вашето име</label>
                            <input asp-for="Name" class="form-control" />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email адрес</label>
                            <input asp-for="Email" class="form-control" />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">Тема</label>
                            <input asp-for="Subject" class="form-control" />
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Message" class="form-label">Съобщение</label>
                            <textarea asp-for="Message" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="Message" class="text-danger"></span>
                        </div>

                        <button type="submit" class="btn btn-primary">Изпрати</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}