@model AutoRent.Web.ViewModels.CarsFilterViewModel
@{
    ViewData["Title"] = "Автомобили";
}

<div class="container py-5">
    <h1 class="text-center mb-5">Нашите автомобили</h1>

    <div class="card mb-4 shadow-sm">
        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-3">
                    <label class="form-label">Марка</label>
                    <select name="brand" class="form-select">
                        <option value="">Всички</option>
                        @foreach (var item in Model.AvailableBrands)

                        {

                            if (Model.Brand == item)

                            {
                                <option value="@item" selected>@item</option>
                            }

                            else

                            {
                                <option value="@item">@item</option>
                            }

                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Тип каросерия</label>
                    <select name="bodyType" class="form-select">
                        <option value="">Всички</option>
                        @foreach (var item in Model.AvailableBodyTypes)

                        {

                            if (Model.BodyType == item)

                            {
                                <option value="@item" selected>@item</option>
                            }

                            else

                            {
                                <option value="@item">@item</option>
                            }

                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Скоростна кутия</label>
                    <select name="transmissionType" class="form-select">
                        <option value="">Всички</option>
                        @foreach (var item in Model.AvailableTransmissionTypes)

                        {

                            if (Model.TransmissionType == item)

                            {
                                <option value="@item" selected>@item</option>
                            }

                            else

                            {
                                <option value="@item">@item</option>
                            }

                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Гориво</label>
                    <select name="fuelType" class="form-select">
                        <option value="">Всички</option>
                        @foreach (var item in Model.AvailableFuelTypes)

                        {

                            if (Model.FuelType == item)

                            {
                                <option value="@item" selected>@item</option>
                            }

                            else

                            {
                                <option value="@item">@item</option>
                            }

                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <label class="form-label">Мин. цена</label>
                    <input type="number" step="0.01" name="minPrice" class="form-control" value="@Model.MinPrice" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Макс. цена</label>
                    <input type="number" step="0.01" name="maxPrice" class="form-control" value="@Model.MaxPrice" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Места</label>
                    <select name="seats" class="form-select">
                        <option value="">Всички</option>
                        @foreach (var item in Model.AvailableSeats)

                        {

                            if (Model.Seats == item)

                            {
                                <option value="@item" selected>@item</option>
                            }

                            else

                            {
                                <option value="@item">@item</option>
                            }

                        }
                    </select>
                </div>

                <div class="col-md-3 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i> Търси
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary w-100">
                        Изчисти
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="row">
        @if (!Model.Cars.Any())

        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-car-front display-1 text-muted"></i>
                <h4 class="mt-3">Няма намерени автомобили</h4>
                <p class="text-muted">Опитайте с други филтри.</p>
            </div>
        }

        else

        {
            @foreach (var car in Model.Cars)

            {
                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <img src="@(car.ImageUrl ?? "https://via.placeholder.com/400x250?text=No+Image")"
                             class="card-img-top"
                             alt="@car.FullName"
                             style="height: 200px; object-fit: cover;">

                        <div class="card-body">
                            <h5 class="card-title">@car.Brand @car.Model</h5>

                            <p class="text-muted mb-2">
                                <span class="badge bg-secondary">@car.BodyType</span>
                                <span class="badge bg-info">@car.TransmissionType</span>
                                <span class="badge bg-dark">@car.FuelType</span>
                                <span class="badge bg-success">@car.Year</span>
                            </p>

                            <p class="small text-muted">
                                Места: @car.Seats
                            </p>

                            <p class="card-text small text-muted">
                                @(string.IsNullOrWhiteSpace(car.Description)
                                    ? "Няма описание за този автомобил."
                                    : car.Description)
                            </p>

                            <p class="card-text">
                                <span class="h4 text-primary">@car.PricePerDay.ToString("N2") лв.</span>
                                <small class="text-muted">/ ден</small>
                            </p>
                        </div>

                        <div class="card-footer bg-white border-top-0">
                            <div class="d-grid gap-2">
                                <a asp-action="Details" asp-route-id="@car.Id" class="btn btn-outline-primary">
                                    <i class="bi bi-eye"></i> Детайли
                                </a>

                                @if (car.IsAvailable)

                                {
                                    <a asp-controller="Cars" asp-action="Rent" asp-route-id="@car.Id" class="btn btn-primary">
                                        <i class="bi bi-calendar-plus"></i> Наеми сега
                                    </a>
                                }

                                else

                                {
                                    <button class="btn btn-secondary" disabled>Не е наличен</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>