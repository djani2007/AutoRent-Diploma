@model AutoRent.Web.ViewModels.AdminUserDetailsViewModel

@{
    ViewData["Title"] = "Информация за клиент";
}

<div class="container py-5">
    <h1 class="mb-4">
        <i class="bi bi-person-vcard"></i> Информация за клиент
    </h1>

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-dark text-white">
            Основна информация
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-6">
                    <strong>Име:</strong>
                    <div>@(string.IsNullOrWhiteSpace(Model.User.FullName) ? "-" : Model.User.FullName)</div>
                </div>

                <div class="col-md-6">
                    <strong>Email:</strong>
                    <div>@(Model.User.Email ?? "-")</div>
                </div>

                <div class="col-md-6">
                    <strong>Телефон:</strong>
                    <div>@(string.IsNullOrWhiteSpace(Model.User.PhoneNumber) ? "-" : Model.User.PhoneNumber)</div>
                </div>
                <div class="col-md-6">
                    <strong>ЕГН:</strong>
                    <div>@Model.User.EGN</div>
                </div>

                <div class="col-md-6">
                    <strong>Дата на раждане:</strong>
                    <div>@Model.User.BirthDate.ToString("dd.MM.yyyy")</div>
                </div>

                <div class="col-md-6">
                    <strong>Лична карта №:</strong>
                    <div>@Model.User.IdentityCardNumber</div>
                </div>

                <div class="col-md-6">
                    <strong>Шофьорска книжка №:</strong>
                    <div>@Model.User.DriverLicenseNumber</div>
                </div>

                <div class="col-md-6">
                    <strong>Книжка издадена на:</strong>
                    <div>@Model.User.DriverLicenseIssueDate.ToString("dd.MM.yyyy")</div>
                </div>

                <div class="col-md-6">
                    <strong>Адрес:</strong>
                    <div>@Model.User.Address</div>
                </div>

                <div class="col-md-6">
                    <strong>Град:</strong>
                    <div>@Model.User.City</div>
                </div>

                <div class="col-md-6">
                    <strong>Роля:</strong>
                    <div>
                        @if (Model.Role == "Admin")
                        {
                            <span class="badge bg-danger">Admin</span>
                        }
                        else
                        {
                            <span class="badge bg-primary">Client</span>
                        }
                    </div>
                </div>

                <div class="col-md-6">
                    <strong>Статус:</strong>
                    <div>
                        @if (Model.User.IsActive)
                        {
                            <span class="badge bg-success">Активен</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Неактивен</span>
                        }
                    </div>
                </div>

                <div class="col-md-6">
                    <strong>Регистриран на:</strong>
                    <div>@Model.User.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Общо наеми</h5>
                    <p class="display-6 mb-0">@Model.TotalRentals</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Активни / чакащи</h5>
                    <p class="display-6 mb-0">@Model.ActiveRentals</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card text-center shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Общо похарчено</h5>
                    <p class="display-6 mb-0">@Model.TotalSpent.ToString("F2") лв.</p>
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white">
            История на наемите
        </div>
        <div class="card-body">
            @if (Model.Rentals.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Автомобил</th>
                                <th>Начало</th>
                                <th>Край</th>
                                <th>Дни</th>
                                <th>Цена</th>
                                <th>Статус</th>
                                <th>Създаден</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rental in Model.Rentals)
                            {
                                <tr>
                                    <td>@rental.Id</td>
                                    <td>
                                        @if (rental.Car != null)
                                        {
                                            @(rental.Car.Brand + " " + rental.Car.Model)
                                        }
                                        else
                                        {
                                            <span>-</span>
                                        }
                                    </td>
                                    <td>@rental.StartDate.ToString("dd.MM.yyyy")</td>
                                    <td>@rental.EndDate.ToString("dd.MM.yyyy")</td>
                                    <td>@rental.TotalDays</td>
                                    <td>@rental.TotalPrice.ToString("F2") лв.</td>
                                    <td>
                                        @if (rental.Status == "Active")
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else if (rental.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                        else if (rental.Status == "Completed")
                                        {
                                            <span class="badge bg-primary">Completed</span>
                                        }
                                        else if (rental.Status == "Cancelled")
                                        {
                                            <span class="badge bg-danger">Cancelled</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">@rental.Status</span>
                                        }
                                    </td>
                                    <td>@rental.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    Този клиент все още няма наеми.
                </div>
            }
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Users" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад към потребителите
        </a>
    </div>
</div>