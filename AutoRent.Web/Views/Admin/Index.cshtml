@model AdminDashboardViewModel
@{
    ViewData["Title"] = "Админ панел";
    Layout = "_Layout";
}

<div class="container py-5">
    <h1 class="mb-4"><i class="bi bi-speedometer2"></i> Админ панел</h1>

    <!-- Statistics Cards -->
    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="card bg-primary text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.TotalCars</h4>
                            <p class="mb-0">Автомобили</p>
                        </div>
                        <i class="bi bi-car-front display-4"></i>
                    </div>
                </div>
                <a asp-action="Cars" class="card-footer text-white text-decoration-none">
                    Управление <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-success text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.TotalUsers</h4>
                            <p class="mb-0">Потребители</p>
                        </div>
                        <i class="bi bi-people display-4"></i>
                    </div>
                </div>
                <a asp-action="Users" class="card-footer text-white text-decoration-none">
                    Управление <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-info text-white h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.TotalRentals</h4>
                            <p class="mb-0">Общо наеми</p>
                        </div>
                        <i class="bi bi-calendar-check display-4"></i>
                    </div>
                </div>
                <a asp-action="Rentals" class="card-footer text-white text-decoration-none">
                    Виж всички <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="card bg-warning text-dark h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <h4 class="mb-0">@Model.ActiveRentals</h4>
                            <p class="mb-0">Активни наеми</p>
                        </div>
                        <i class="bi bi-clock-history display-4"></i>
                    </div>
                </div>
                <a asp-action="Rentals" class="card-footer text-dark text-decoration-none">
                    Виж активни <i class="bi bi-arrow-right"></i>
                </a>
            </div>
        </div>
    </div>

    <!-- Quick Actions -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Бързи действия</h5>
                </div>
                <div class="card-body">
                    <a asp-action="CreateCar" class="btn btn-primary me-2">
                        <i class="bi bi-plus-circle"></i> Добави автомобил
                    </a>
                    <a asp-action="Cars" class="btn btn-outline-primary me-2">
                        <i class="bi bi-car-front"></i> Управление на автомобили
                    </a>
                    <a asp-action="Users" class="btn btn-outline-success me-2">
                        <i class="bi bi-people"></i> Управление на потребители
                    </a>
                    <a asp-action="Rentals" class="btn btn-outline-info me-2">
                        <i class="bi bi-calendar-check"></i> История на наемите
                    </a>
                    <a asp-action="Messages" class="btn btn-outline-warning">
                        <i class="bi bi-envelope"></i> Съобщения
                        @if (Model.UnreadMessagesCount > 0)

                        {
                            <span class="badge bg-danger ms-1">@Model.UnreadMessagesCount</span>
                        }
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header">
            <h5 class="mb-0">Последни съобщения</h5>
        </div>
        <div class="card-body">
            @if (Model.RecentMessages.Any())
            {
                <div class="list-group">
                    @foreach (var message in Model.RecentMessages)
                    {
                        <a asp-action="Messages" class="list-group-item list-group-item-action">
                            <div class="d-flex justify-content-between">
                                <strong>@message.Subject</strong>
                                <small>@message.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</small>
                            </div>
                            <div>@message.Name (@message.Email)</div>
                            <small class="text-muted">
                                @(message.Message.Length > 100 ? message.Message.Substring(0, 100) + "..." : message.Message)
                            </small>
                        </a>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Няма нови съобщения.</p>
            }
        </div>
    </div>

    <!-- Recent Rentals -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">Последни резервации</h5>
        </div>
        <div class="card-body">
            @if (Model.RecentRentals.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Потребител</th>
                                <th>Автомобил</th>
                                <th>Период</th>
                                <th>Сума</th>
                                <th>Статус</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rental in Model.RecentRentals)
                            {
                                <tr>
                                    <td>@rental.Id</td>
                                    <td>@rental.User.FullName</td>
                                    <td>@rental.Car.FullName</td>
                                    <td>@rental.StartDate.ToString("dd.MM") - @rental.EndDate.ToString("dd.MM.yyyy")</td>
                                    <td>@rental.TotalPrice.ToString("N2") €</td>
                                    <td>
                                        @switch (rental.Status)
                                        {
                                            case "Pending":
                                                <span class="badge bg-warning">В изчакване</span>
                                                break;
                                            case "Active":
                                                <span class="badge bg-success">Активен</span>
                                                break;
                                            case "Completed":
                                                <span class="badge bg-secondary">Завършен</span>
                                                break;
                                            case "Cancelled":
                                                <span class="badge bg-danger">Отказан</span>
                                                break;
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p class="text-muted mb-0">Няма резервации.</p>
            }
        </div>
    </div>
</div>
