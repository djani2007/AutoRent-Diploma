@model IEnumerable<Rental>
@{
    ViewData["Title"] = "История на наемите";
}

<div class="container py-5">
    <h1 class="mb-4"><i class="bi bi-calendar-check"></i> История на наемите</h1>

    <div class="card">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Потребител</th>
                            <th>Автомобил</th>
                            <th>Начало</th>
                            <th>Край</th>
                            <th>Дни</th>
                            <th>Сума</th>
                            <th>Статус</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var rental in Model)
                        {
                            <tr>
                                <td>@rental.Id</td>
                                <td>
                                    @rental.User.FullName
                                    <br /><small class="text-muted">@rental.User.Email</small>
                                </td>
                                <td>@rental.Car.FullName</td>
                                <td>@rental.StartDate.ToString("dd.MM.yyyy")</td>
                                <td>@rental.EndDate.ToString("dd.MM.yyyy")</td>
                                <td>@rental.TotalDays</td>
                                <td>@rental.TotalPrice.ToString("N2") €</td>
                                <td>
                                    @switch (rental.Status)
                                    {
                                        case "Pending":
                                            <span class="badge bg-warning">В изчакване</span>
                                            break;
                                        case "Active":
                                            <span class="badge bg-success">Активен</span>
                                            break;
                                        case "Completed":
                                            <span class="badge bg-secondary">Завършен</span>
                                            break;
                                        case "Cancelled":
                                            <span class="badge bg-danger">Отказан</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (rental.Status == "Pending")

                                    {
                                        <div class="btn-group btn-group-sm">
                                            <form asp-action="UpdateRentalStatus" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@rental.Id" />
                                                <input type="hidden" name="status" value="Active" />
                                                <button type="submit" class="btn btn-success" title="Активирай">
                                                    <i class="bi bi-check"></i>
                                                </button>
                                            </form>

                                            <form asp-action="UpdateRentalStatus" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="id" value="@rental.Id" />
                                                <input type="hidden" name="status" value="Cancelled" />
                                                <button type="submit" class="btn btn-danger" title="Откажи">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </form>
                                        </div>
                                    }

                                    else

                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад към панела
        </a>
    </div>
</div>
