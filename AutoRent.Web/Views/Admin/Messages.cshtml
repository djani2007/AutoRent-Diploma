@model IEnumerable<AutoRent.Core.Entities.ContactMessage>

@{
    ViewData["Title"] = "Съобщения";
}

<div class="container py-5">
    <h1 class="mb-4">
        <i class="bi bi-envelope"></i> Съобщения от контакти
    </h1>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>#</th>
                                <th>Име</th>
                                <th>Email</th>
                                <th>Тема</th>
                                <th>Съобщение</th>
                                <th>Дата</th>
                                <th>Статус</th>
                                <th>Действия</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr class="@(item.IsRead ? "" : "table-warning")">
                                    <td>@item.Id</td>
                                    <td>@item.Name</td>
                                    <td>@item.Email</td>
                                    <td>@item.Subject</td>
                                    <td style="max-width: 320px; white-space: pre-wrap;">@item.Message</td>
                                    <td>@item.CreatedAt.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>

                                    <td>
                                        @if (item.RequestType == "ProfileChange")
                                        {
                                            if (item.RequestStatus == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">В изчакване</span>
                                            }
                                            else if (item.RequestStatus == "Approved")
                                            {
                                                <span class="badge bg-success">Одобрена</span>
                                            }
                                            else if (item.RequestStatus == "Rejected")
                                            {
                                                <span class="badge bg-secondary">Отказана</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-info">Заявка</span>
                                            }
                                        }
                                        else
                                        {
                                            if (item.IsRead)
                                            {
                                                <span class="badge bg-success">Прочетено</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-danger">Непрочетено</span>
                                            }
                                        }
                                    </td>

                                    <td>
                                        @if (item.RequestType == "ProfileChange" && item.RequestStatus == "Pending")
                                        {
                                            <form asp-action="ApproveProfileChange" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-success mb-1"
                                                        onclick="return confirm('Сигурни ли сте, че искате да одобрите тази промяна?');">
                                                    <i class="bi bi-check-circle"></i> Одобри
                                                </button>
                                            </form>

                                            <form asp-action="RejectProfileChange" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-warning mb-1"
                                                        onclick="return confirm('Сигурни ли сте, че искате да откажете тази промяна?');">
                                                    <i class="bi bi-x-circle"></i> Откажи
                                                </button>
                                            </form>
                                        }
                                        else if (!item.IsRead)
                                        {
                                            <form asp-action="MarkMessageAsRead" asp-route-id="@item.Id" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-primary mb-1">
                                                    <i class="bi bi-check2-circle"></i> Прочети
                                                </button>
                                            </form>
                                        }

                                        <form asp-action="DeleteMessage" asp-route-id="@item.Id" method="post" class="d-inline"
                                              onsubmit="return confirm('Сигурни ли сте, че искате да изтриете това съобщение?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger mb-1">
                                                <i class="bi bi-trash"></i> Изтрий
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    Няма получени съобщения.
                </div>
            }
        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Назад към панела
        </a>
    </div>
</div>