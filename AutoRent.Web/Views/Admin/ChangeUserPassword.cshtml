@model AutoRent.Web.ViewModels.AdminChangePasswordViewModel

@{
    ViewData["Title"] = "Смяна на парола";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-header bg-danger text-white py-4">
                    <h3 class="mb-0">
                        <i class="bi bi-key me-2"></i> Смяна на парола
                    </h3>
                </div>

                <div class="card-body p-4">
                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle me-1"></i>
                        Администраторът не може да вижда старата парола. Може само да зададе нова.
                    </div>

                    <div class="mb-3">
                        <strong>Потребител:</strong> @Model.FullName
                    </div>

                    <div class="mb-3">
                        <strong>Имейл:</strong> @Model.Email
                    </div>

                    <form asp-action="ChangeUserPassword" method="post">
                        @Html.AntiForgeryToken()

                        <input type="hidden" asp-for="UserId" />
                        <input type="hidden" asp-for="Email" />
                        <input type="hidden" asp-for="FullName" />

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">Нова парола</label>
                            <input asp-for="NewPassword" class="form-control form-control-lg" placeholder="Въведете нова парола" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Потвърди парола</label>
                            <input asp-for="ConfirmPassword" class="form-control form-control-lg" placeholder="Повторете новата парола" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-check-circle me-1"></i> Смени паролата
                            </button>

                            <a asp-action="Users" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Назад
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}